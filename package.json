{
	"name": "@anvilkit/canvas-core",
	"version": "0.1.2",
	"description": "Headless Canvas IR, Zod validators, walkers, mutations, and serializers for AnvilKit Canvas Studio. No React, no Konva.",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"license": "MIT",
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"pdf-lib": "^1.17.1",
		"zod": "^4.4.3"
	},
	"scripts": {
		"build": "rslib build",
		"dev": "rslib build --watch",
		"lint": "pnpm exec biome lint package.json tsconfig.json rslib.config.ts vitest.config.ts src",
		"format": "pnpm exec biome check --write package.json tsconfig.json rslib.config.ts vitest.config.ts src",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"publint": "publint",
		"size": "size-limit"
	},
	"devDependencies": {
		"@anvilkit/biome-config": "workspace:*",
		"@anvilkit/typescript-config": "workspace:*",
		"@anvilkit/vitest-config": "workspace:*",
		"@rslib/core": "^0.22.0",
		"@types/node": "^25.9.1",
		"publint": "^0.3.21",
		"typescript": "6.0.3",
		"vitest": "^4.1.7"
	}
}
